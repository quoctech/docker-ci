# Docker Compose Environment
# Copy this file to .env and adjust as needed

# MariaDB
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ci4_db
DB_USERNAME=ci4_user
DB_PASSWORD=ci4_pass

# Nginx
NGINX_PORT=80

# PHP
PHP_VERSION=8.5

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (MUST change in production)
JWT_SECRET_KEY=your-super-secret-key-change-this-min-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
